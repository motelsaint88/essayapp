# Copy this file to .env and fill in your own values.

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — model to use for grading (default is fine)
GEMINI_MODEL=gemini-2.5-flash

# Any random long string, used to sign login session cookies
SESSION_SECRET=change-this-to-something-random-and-long

# Port the server listens on (most hosts set this automatically)
PORT=3000

# --- Database ---
# Leave both of these BLANK for local development — the app will just use a
# local SQLite file at ./data/local.db automatically, no setup needed.
#
# For deploying somewhere with no persistent disk (e.g. Render's free tier),
# create a free database at https://turso.tech, then run in their CLI:
#   turso db create essay-app
#   turso db show essay-app --url          <- paste as TURSO_DATABASE_URL
#   turso db tokens create essay-app        <- paste as TURSO_AUTH_TOKEN
# This stores your data in the cloud so it survives restarts/redeploys even
# without a persistent disk.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
